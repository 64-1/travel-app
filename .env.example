# Local dev: use a free Neon Postgres URL (https://neon.tech) or any PostgreSQL database.
# For Vercel: use Neon's *pooled* connection string (ends with -pooler).
DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/travel_planner?sslmode=require"

# Optional — enables live AI suggestions (mock data used if unset)
OPENAI_API_KEY=""

# Optional
SERPER_API_KEY=""
GOOGLE_PLACES_API_KEY=""

# Public site URL for share links and Open Graph metadata.
# On Vercel, set to your production domain (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
